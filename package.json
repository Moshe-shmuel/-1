{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "description": "אפליקציה להדגשת טקסטים תורניים עם תמיכה באופליין",
  "author": "Highlight App Team",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
