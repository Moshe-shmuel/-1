{
  "productName": "מדגיש אוטומטי",
  "version": "1.0.0",
  "identifier": "com.highlight.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "מדגיש אוטומטי",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "databases": ["sqlite:highlight.db"]
    },
    "fs": {
      "scope": ["$RESOURCE/*"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["sources/**/*.txt"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}